# Copy to `.opencode/langsmith.env` and fill in values.
# This file is auto-loaded by the opencode-langsmith-tracing plugin at
# opencode startup. Values here do NOT override env vars already set in
# the shell.

LANGSMITH_TRACING=true
OC_LANGSMITH_API_KEY=lsv2_pt_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OC_LANGSMITH_PROJECT=opencode

# Optional — point to a self-hosted LangSmith deployment.
# OC_LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# CC_LANGSMITH_* and bare LANGSMITH_* variants are also accepted, so the
# same env file can be reused for langsmith-claude-code-plugins.
